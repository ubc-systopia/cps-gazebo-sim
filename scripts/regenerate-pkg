#!/bin/bash
# regenerate-pkg - Re-derive a previously generated ROS package from its
# config/robots.json, without going through the interactive create-ros-pkg CLI.
#
# Workflow:
#   1. edit src/<pkg>/config/robots.json    (move arms, swap UR types, add/remove arms, ...)
#   2. ./scripts/regenerate-pkg <pkg>       (re-emits urdf/, config/, launch/, scripts/workflow_demo.py)
#   3. colcon build --packages-select <pkg> && relaunch
#
# What it touches: urdf/*, config/*.yaml, config/*.srdf, config/*.rviz,
#                  launch/demo.launch.py, scripts/workflow_demo.py
# What it LEAVES alone: package.xml, CMakeLists.txt, config/robots.json (the source).

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WORKSPACE_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SRC_DIR="${WORKSPACE_ROOT}/src"

RED='\033[0;31m'; GREEN='\033[0;32m'; BLUE='\033[0;34m'; YELLOW='\033[1;33m'; NC='\033[0m'
info()    { echo -e "${BLUE}[INFO]${NC} $*"; }
success() { echo -e "${GREEN}[OK]${NC} $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC} $*"; }
error()   { echo -e "${RED}[ERROR]${NC} $*" >&2; }

usage() {
  cat <<EOF
Usage: $(basename "$0") [--no-build] <package_name>

Re-derives all generated files in src/<package_name>/ from that package's
config/robots.json, then runs colcon build --packages-select <package_name>.
Use --no-build to skip the build step (e.g. to inspect the regenerated files).

Example:
  \$EDITOR src/diff_robots/config/robots.json
  ./scripts/regenerate-pkg diff_robots
  # then: source install/setup.bash and relaunch
EOF
}

NO_BUILD=0
ARGS=()
for a in "$@"; do
  case "$a" in
    --no-build) NO_BUILD=1 ;;
    -h|--help) usage; exit 2 ;;
    -*) error "Unknown flag: $a"; usage; exit 2 ;;
    *) ARGS+=("$a") ;;
  esac
done
if [ ${#ARGS[@]} -ne 1 ]; then usage; exit 2; fi
PACKAGE_NAME="${ARGS[0]}"
PKG_DIR="${SRC_DIR}/${PACKAGE_NAME}"
ROBOTS_JSON="${PKG_DIR}/config/robots.json"

# --- validation -------------------------------------------------------------
if [ ! -d "$PKG_DIR" ]; then
  error "Package not found: $PKG_DIR"; exit 1
fi
if [ ! -f "$ROBOTS_JSON" ]; then
  error "Not a regenerable package: $ROBOTS_JSON does not exist."
  error "(regenerate-pkg only works on packages produced by create-ros-pkg.)"
  exit 1
fi
if ! command -v python3 >/dev/null 2>&1; then
  error "python3 is required to parse robots.json."; exit 1
fi
if ! python3 -c "import json,sys; json.load(open(sys.argv[1]))" "$ROBOTS_JSON" 2>/dev/null; then
  error "$ROBOTS_JSON is not valid JSON."; exit 1
fi

# --- self-source ROS so the script works from a plain shell ----------------
# (only sources humble if no ROS distro is already active, to respect the user's env)
set +e
if [ -z "${ROS_DISTRO:-}" ] && [ -f /opt/ros/humble/setup.bash ]; then
  info "Sourcing /opt/ros/humble/setup.bash"
  source /opt/ros/humble/setup.bash
fi
if [ -f "${WORKSPACE_ROOT}/install/setup.bash" ]; then
  info "Sourcing ${WORKSPACE_ROOT}/install/setup.bash"
  source "${WORKSPACE_ROOT}/install/setup.bash"
else
  info "install/setup.bash not found yet (first build?) - colcon will create it."
fi
set -e

# --- friendly warning about uncommitted edits in generated files -----------
if command -v git >/dev/null 2>&1 && git -C "$WORKSPACE_ROOT" rev-parse >/dev/null 2>&1; then
  dirty=$(git -C "$WORKSPACE_ROOT" status --porcelain -- \
    "src/${PACKAGE_NAME}/urdf" \
    "src/${PACKAGE_NAME}/config" \
    "src/${PACKAGE_NAME}/launch" \
    "src/${PACKAGE_NAME}/scripts/workflow_demo.py" 2>/dev/null || true)
  if [ -n "$dirty" ]; then
    warn "Uncommitted changes in generated files for ${PACKAGE_NAME}:"
    echo "$dirty" | sed 's/^/        /'
    warn "Regeneration will overwrite these. Ctrl-C within 3s to abort..."
    sleep 3
  fi
fi

info "Regenerating ${PACKAGE_NAME} from ${ROBOTS_JSON}"

# --- parse JSON into the same arrays create-ros-pkg's main() builds --------
mapfile -t robot_names < <(python3 - "$ROBOTS_JSON" <<'PY'
import json, sys
for a in json.load(open(sys.argv[1]))["robot_arms"]:
    print(a["key"])
PY
)
mapfile -t robot_specs < <(python3 - "$ROBOTS_JSON" <<'PY'
import json, sys
for a in json.load(open(sys.argv[1]))["robot_arms"]:
    bc, ij = a["base_coordinates"], a["initial_joints"]
    print(":".join(str(v) for v in [
        a["key"], a["model"],
        bc["x"], bc["y"], bc["z"], bc["R"], bc["P"], bc["Y"],
        ij["shoulder_pan"], ij["shoulder_lift"], ij["elbow"],
        ij["wrist_1"], ij["wrist_2"], ij["wrist_3"],
    ]))
PY
)
mapfile -t initial_positions < <(python3 - "$ROBOTS_JSON" <<'PY'
import json, sys
for a in json.load(open(sys.argv[1]))["robot_arms"]:
    ij = a["initial_joints"]
    joints = ",".join(str(ij[k]) for k in
                      ("shoulder_pan","shoulder_lift","elbow","wrist_1","wrist_2","wrist_3"))
    print(f'{a["key"]}:{joints}')
PY
)

if [ ${#robot_names[@]} -eq 0 ]; then
  error "robots.json contains no robot_arms entries."; exit 1
fi

controller_args=()
for name in "${robot_names[@]}"; do
  joints="${name}_shoulder_pan_joint,${name}_shoulder_lift_joint,${name}_elbow_joint,${name}_wrist_1_joint,${name}_wrist_2_joint,${name}_wrist_3_joint"
  controller_args+=("${name}_joint_trajectory_controller:${joints}")
done

info "Arms (${#robot_names[@]}): ${robot_names[*]}"

# --- ensure the standard output dirs exist ---------------------------------
mkdir -p "${PKG_DIR}/urdf" "${PKG_DIR}/config" "${PKG_DIR}/launch" "${PKG_DIR}/scripts"

# --- re-invoke the same helpers create-ros-pkg uses ------------------------
# Deliberately SKIPPED: package_xml, cmakelists, robots_json (the source),
#                      launch_script (lives in workspace scripts/, not pkg).
H="${SCRIPT_DIR}/helpers"

bash "$H/generate_demo_launch.sh"                  "$PACKAGE_NAME" "$PKG_DIR"
bash "$H/generate_joint_limits.sh"                 "$PACKAGE_NAME" "$PKG_DIR" "${robot_names[@]}"
bash "$H/generate_kinematics.sh"                   "$PACKAGE_NAME" "$PKG_DIR" "${robot_names[@]}"
bash "$H/generate_initial_positions.sh"            "$PACKAGE_NAME" "$PKG_DIR" "${initial_positions[@]}"
bash "$H/generate_controllers.sh"                  "$PACKAGE_NAME" "$PKG_DIR" "${controller_args[@]}"
bash "$H/generate_moveit_controllers.sh"           "$PACKAGE_NAME" "$PKG_DIR" "${controller_args[@]}"
bash "$H/generate_srdf.sh"                         "$PACKAGE_NAME" "$PKG_DIR" "${robot_names[@]}"
bash "$H/generate_rviz_config.sh"                  "$PACKAGE_NAME" "$PKG_DIR" "${robot_names[@]}"
bash "$H/generate_workflow_demo.sh"                "$PACKAGE_NAME" "$PKG_DIR"
bash "$H/generate_sensors_3d.sh"                   "$PACKAGE_NAME" "$PKG_DIR"
bash "$H/generate_pilz_cartesian_limits.sh"        "$PACKAGE_NAME" "$PKG_DIR"
bash "$H/generate_pkg_xacro.sh"                    "$PACKAGE_NAME" "$PKG_DIR" "${robot_specs[@]}"
bash "$H/generate_robot_description_template.sh"   "$PACKAGE_NAME" "$PKG_DIR" "${robot_specs[@]}"
bash "$H/generate_robot_description_wrapper.sh"    "$PACKAGE_NAME" "$PKG_DIR"
bash "$H/generate_ros2_control_xacro.sh"           "$PACKAGE_NAME" "$PKG_DIR" "${robot_names[@]}"
bash "$H/generate_static_robot_description.sh"     "$PACKAGE_NAME" "$PKG_DIR" || true

# --- expand the main XACRO into the flat URDF (same logic as create-ros-pkg)
XACRO_PATH="${PKG_DIR}/urdf/${PACKAGE_NAME}.urdf.xacro"
URDF_PATH="${PKG_DIR}/urdf/${PACKAGE_NAME}.urdf"
if [ -f "$XACRO_PATH" ]; then
  status=0
  if command -v xacro >/dev/null 2>&1; then
    xacro "$XACRO_PATH" -o "$URDF_PATH" 2>/dev/null || status=$?
  elif command -v ros2 >/dev/null 2>&1; then
    ros2 run xacro xacro "$XACRO_PATH" -o "$URDF_PATH" 2>/dev/null || status=$?
  elif python3 -c 'import xacro' 2>/dev/null; then
    python3 -m xacro "$XACRO_PATH" -o "$URDF_PATH" 2>/dev/null || status=$?
  else
    warn "xacro CLI not found; flat URDF not regenerated. Source ROS, then re-run."
    status=127
  fi
  if [ "$status" -eq 0 ] && [ -f "$URDF_PATH" ]; then
    success "URDF regenerated: $(basename "$URDF_PATH")"
  elif [ "$status" -ne 0 ]; then
    warn "xacro expansion failed (exit=$status). Flat URDF not regenerated."
    warn "Usually means install/setup.bash isn't sourced (so multi_ur_description isn't findable)."
  fi
else
  warn "Expected XACRO not found at $XACRO_PATH (skipping URDF expansion)."
fi

success "Regenerated ${PACKAGE_NAME}"

# --- optional colcon build -------------------------------------------------
if [ "$NO_BUILD" = "1" ]; then
  info "Skipping build (--no-build). To finish: colcon build --packages-select ${PACKAGE_NAME}"
  exit 0
fi
if ! command -v colcon >/dev/null 2>&1; then
  warn "colcon not found; skipping build. (Did you 'source /opt/ros/humble/setup.bash'?)"
  warn "Run manually: colcon build --packages-select ${PACKAGE_NAME}"
  exit 0
fi
info "Building: colcon build --packages-select ${PACKAGE_NAME}"
if ( cd "$WORKSPACE_ROOT" && colcon build --packages-select "$PACKAGE_NAME" ); then
  success "Built ${PACKAGE_NAME}"
  echo
  info "Next: source install/setup.bash (if not already), then relaunch."
  info "(move_group must be relaunched to reload SRDF / kinematics.)"
else
  error "colcon build failed for ${PACKAGE_NAME}"
  exit 1
fi
