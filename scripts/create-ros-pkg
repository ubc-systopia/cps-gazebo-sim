#!/bin/bash

# create-ros-pkg - Enhanced script to create ROS packages with multiple UR robots

set -e

# Resolve workspace root and src directory (script is in <ws>/scripts)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WORKSPACE_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SRC_DIR="${WORKSPACE_ROOT}/src"
# Generated packages live under src/generated/ to keep them separate from the
# hand-authored packages in src/. colcon discovers them recursively either way.
GENERATED_DIR="${SRC_DIR}/generated"

# Available UR robot types (from multi_ur_description/config)
UR_TYPES=("ur3" "ur3e" "ur5" "ur5e" "ur10" "ur10e" "ur16e" "ur20" "ur30")

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Arrays to store robot configurations
declare -a ROBOT_UR_TYPES
declare -a ROBOT_X_POSITIONS
declare -a ROBOT_Y_POSITIONS
declare -a ROBOT_Z_POSITIONS
declare -a ROBOT_ROLLS
declare -a ROBOT_PITCHES
declare -a ROBOT_YAWS
declare -a ROBOT_SHOULDER_PANS
declare -a ROBOT_SHOULDER_LIFTS
declare -a ROBOT_ELBOWS
declare -a ROBOT_WRIST_1S
declare -a ROBOT_WRIST_2S
declare -a ROBOT_WRIST_3S

# Function to print colored output
print_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Function to validate numeric input
validate_number() {
    local input=$1
    local min=$2
    local max=$3
    
    if ! [[ "$input" =~ ^[0-9]+$ ]]; then
        return 1
    fi
    
    if [ "$input" -lt "$min" ] || [ "$input" -gt "$max" ]; then
        return 1
    fi
    
    return 0
}

# Function to validate float input
validate_float() {
    local input=$1
    if ! [[ "$input" =~ ^-?[0-9]+\.?[0-9]*$ ]]; then
        return 1
    fi
    return 0
}

# Function to get user input with validation
get_number_input() {
    local prompt=$1
    local min=$2
    local max=$3
    local input
    
    while true; do
        echo -n "$prompt ($min-$max): " >&2
        read input
        
        if validate_number "$input" "$min" "$max"; then
            echo "$input"
            return 0
        else
            print_error "Please enter a valid number between $min and $max" >&2
        fi
    done
}

# Function to get float input with validation
get_float_input() {
    local prompt=$1
    local input
    
    while true; do
        echo -n "$prompt: " >&2
        read input
        
        if validate_float "$input"; then
            echo "$input"
            return 0
        else
            print_error "Please enter a valid number (e.g., 1.57, -2.0, 0)" >&2
        fi
    done
}

# Function to select UR robot type
select_ur_type() {
    local robot_num=$1
    
    echo "" >&2
    print_info "Available UR robot types for Robot $robot_num:" >&2
    for i in "${!UR_TYPES[@]}"; do
        echo "  $((i+1)). ${UR_TYPES[i]}" >&2
    done
    
    local choice
    choice=$(get_number_input "Select UR robot type" 1 ${#UR_TYPES[@]})
    echo "${UR_TYPES[$((choice-1))]}"
}

# Function to get robot configuration
get_robot_config() {
    local robot_num=$1
    local index=$((robot_num-1))
    
    print_info "Configuring Robot $robot_num"
    echo ""
    
    # Get UR type
    ROBOT_UR_TYPES[$index]=$(select_ur_type "$robot_num")
    
    # Get starting position (x, y, z)
    echo ""
    print_info "Starting position for Robot $robot_num:"
    ROBOT_X_POSITIONS[$index]=$(get_float_input "X position (meters)")
    ROBOT_Y_POSITIONS[$index]=$(get_float_input "Y position (meters)")  
    ROBOT_Z_POSITIONS[$index]=$(get_float_input "Z position (meters)")
    
    # Get starting orientation (roll, pitch, yaw)
    echo ""
    print_info "Starting orientation for Robot $robot_num (in radians):"
    ROBOT_ROLLS[$index]=$(get_float_input "Roll (rotation around X-axis)")
    ROBOT_PITCHES[$index]=$(get_float_input "Pitch (rotation around Y-axis)")
    ROBOT_YAWS[$index]=$(get_float_input "Yaw (rotation around Z-axis)")
    
    # Get starting joint values
    echo ""
    print_info "Starting joint values for Robot $robot_num (in radians):"
    ROBOT_SHOULDER_PANS[$index]=$(get_float_input "Shoulder Pan Joint")
    ROBOT_SHOULDER_LIFTS[$index]=$(get_float_input "Shoulder Lift Joint")
    ROBOT_ELBOWS[$index]=$(get_float_input "Elbow Joint")
    ROBOT_WRIST_1S[$index]=$(get_float_input "Wrist 1 Joint")
    ROBOT_WRIST_2S[$index]=$(get_float_input "Wrist 2 Joint")
    ROBOT_WRIST_3S[$index]=$(get_float_input "Wrist 3 Joint")
    
    print_success "Robot $robot_num configuration completed!"
}

# Function to display configuration summary
display_summary() {
    local num_robots=$1
    
    echo ""
    print_info "Configuration Summary:"
    echo "====================="
    echo "Number of robots: $num_robots"
    echo ""
    
    for ((i=1; i<=num_robots; i++)); do
        local index=$((i-1))
        echo "Robot $i:"
        echo "  UR Type: ${ROBOT_UR_TYPES[$index]}"
        echo "  Position: x=${ROBOT_X_POSITIONS[$index]}, y=${ROBOT_Y_POSITIONS[$index]}, z=${ROBOT_Z_POSITIONS[$index]}"
        echo "  Orientation: roll=${ROBOT_ROLLS[$index]}, pitch=${ROBOT_PITCHES[$index]}, yaw=${ROBOT_YAWS[$index]}"
        echo "  Joint Values:"
        echo "    Shoulder Pan: ${ROBOT_SHOULDER_PANS[$index]}"
        echo "    Shoulder Lift: ${ROBOT_SHOULDER_LIFTS[$index]}"
        echo "    Elbow: ${ROBOT_ELBOWS[$index]}"
        echo "    Wrist 1: ${ROBOT_WRIST_1S[$index]}"
        echo "    Wrist 2: ${ROBOT_WRIST_2S[$index]}"
        echo "    Wrist 3: ${ROBOT_WRIST_3S[$index]}"
        echo ""
    done
}

# Expand a XACRO file into a URDF file.
# NON-FATAL: a brand-new package's main XACRO contains a self-reference
# ($(find <pkg>)/config/controllers.yaml) that cannot resolve until the package
# is installed, so this pre-build expansion is expected to fail on first
# creation. The flat .urdf is not needed for the build or launch (demo.launch.py
# expands the .urdf.xacro directly post-build), so we warn and continue rather
# than aborting before colcon build. Always returns 0.
expand_xacro_to_urdf() {
  local xacro_file=$1
  local urdf_file=$2
  local status=0
  print_info "Generating URDF from XACRO: $(basename "$xacro_file")"
  if command -v xacro >/dev/null 2>&1; then
    xacro "$xacro_file" -o "$urdf_file" 2>/dev/null || status=$?
  elif command -v ros2 >/dev/null 2>&1; then
    ros2 run xacro xacro "$xacro_file" -o "$urdf_file" 2>/dev/null || status=$?
  else
    if python3 - << 'PY'
import sys
try:
    import xacro  # noqa: F401
except Exception:
    sys.exit(1)
PY
    then
      python3 -m xacro "$xacro_file" -o "$urdf_file" 2>/dev/null || status=$?
    else
      print_warning "Could not find xacro CLI; skipping flat URDF (it is regenerated at launch)."
      return 0
    fi
  fi
  if [ "$status" -eq 0 ] && [ -f "$urdf_file" ]; then
    print_success "URDF generated: $urdf_file"
  else
    print_warning "Flat URDF not generated yet (exit=$status). This is normal on first creation"
    print_warning "(the XACRO self-references \$(find ${package_name}), resolvable only after build)."
    print_warning "It is expanded automatically at launch, or run regenerate-pkg after the build."
  fi
  return 0
}
# Load package config from a predefined JSON spec (--from-json mode).
# Sets globals: PACKAGE_NAME_FROM_JSON, LAUNCH_RVIZ_FROM_JSON, and the parallel
# arrays JSON_ROBOT_NAMES, JSON_ROBOT_SPECS, JSON_INITIAL_POSITIONS.
load_from_json() {
  local path="$1"
  if [ -z "$path" ]; then
    print_error "--from-json requires a path"; exit 2
  fi
  if [ ! -f "$path" ]; then
    print_error "JSON file not found: $path"; exit 1
  fi
  if ! python3 -c "import json,sys; json.load(open(sys.argv[1]))" "$path" 2>/dev/null; then
    print_error "Not valid JSON: $path"; exit 1
  fi

  local _json_lines
  mapfile -t _json_lines < <(python3 - "$path" <<'PY'
import json, sys
d = json.load(open(sys.argv[1]))
missing = [k for k in ("package_name", "robot_arms") if k not in d]
if missing or not d.get("robot_arms"):
    sys.stderr.write("missing/empty: " + (", ".join(missing) or "robot_arms (non-empty)") + "\n")
    sys.exit(2)
print(d["package_name"])
print("true" if d.get("launch_rviz", True) else "false")
for a in d["robot_arms"]:
    bc, ij = a["base_coordinates"], a["initial_joints"]
    print(":".join(str(v) for v in [
        a["key"], a["model"],
        bc["x"], bc["y"], bc["z"], bc["R"], bc["P"], bc["Y"],
        ij["shoulder_pan"], ij["shoulder_lift"], ij["elbow"],
        ij["wrist_1"], ij["wrist_2"], ij["wrist_3"],
    ]))
PY
  )

  if [ "${#_json_lines[@]}" -lt 3 ]; then
    print_error "JSON missing required fields (need package_name and at least one robot_arms entry)"
    exit 1
  fi

  PACKAGE_NAME_FROM_JSON="${_json_lines[0]}"
  LAUNCH_RVIZ_FROM_JSON="${_json_lines[1]}"
  JSON_ROBOT_SPECS=("${_json_lines[@]:2}")
  JSON_ROBOT_NAMES=()
  JSON_INITIAL_POSITIONS=()
  local spec key model x y z R P Y pan lift elbow w1 w2 w3
  for spec in "${JSON_ROBOT_SPECS[@]}"; do
    IFS=':' read -r key model x y z R P Y pan lift elbow w1 w2 w3 <<< "$spec"
    JSON_ROBOT_NAMES+=("$key")
    JSON_INITIAL_POSITIONS+=("${key}:${pan},${lift},${elbow},${w1},${w2},${w3}")
  done
}

# Main function
main() {
    # ---- CLI flags -------------------------------------------------------
    local FROM_JSON_PATH=""
    local RABIT_PATH=""
    local NO_BUILD=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --from-json)
                if [ -z "${2:-}" ]; then print_error "--from-json requires a path"; exit 2; fi
                FROM_JSON_PATH="$2"; shift 2 ;;
            --from-json=*) FROM_JSON_PATH="${1#*=}"; shift ;;
            --rabit)
                if [ -z "${2:-}" ]; then print_error "--rabit requires a path"; exit 2; fi
                RABIT_PATH="$2"; shift 2 ;;
            --rabit=*) RABIT_PATH="${1#*=}"; shift ;;
            --no-build) NO_BUILD=1; shift ;;
            -h|--help)
                cat <<EOF
Usage: $(basename "$0") [--no-build]                          # interactive
       $(basename "$0") --from-json <file.json> [--no-build]  # from a diff_robots-style spec
       $(basename "$0") --rabit <file.json> [--no-build]      # from a general-schema (RABIT) config

By default the script also runs colcon build for the new package. Pass
--no-build to generate the files only.

--from-json takes a flat diff_robots.json-style spec (see configs/examples/simulator-schema/diff_robots.json).
--rabit takes a general-schema lab config (see configs/examples/rabit-schema/rabit-config-2.json); it is
translated to the diff_robots format via scripts/translate-config and then used
exactly like --from-json. The two flags are mutually exclusive.
EOF
                exit 0 ;;
            -*) print_error "Unknown flag: $1"; exit 2 ;;
            *)  print_error "Unexpected positional arg: $1"; exit 2 ;;
        esac
    done

    # ---- RABIT translation step -----------------------------------------
    # When --rabit is given, translate the general-schema config into a flat
    # diff_robots spec (temp file) and feed it through the normal --from-json path.
    if [ -n "$RABIT_PATH" ]; then
        if [ -n "$FROM_JSON_PATH" ]; then
            print_error "--rabit and --from-json are mutually exclusive"; exit 2
        fi
        if [ ! -f "$RABIT_PATH" ]; then
            print_error "--rabit file not found: $RABIT_PATH"; exit 1
        fi
        FROM_JSON_PATH="$(mktemp -t rabit-translated-XXXXXX.json)"
        print_info "Translating RABIT/general-schema config: $RABIT_PATH"
        if ! python3 "${SCRIPT_DIR}/translate-config" "$RABIT_PATH" "$FROM_JSON_PATH"; then
            print_error "translation failed (see scripts/translate-config output above)"; exit 1
        fi
        print_info "Translated spec written to: $FROM_JSON_PATH"
    fi

    # ---- Self-source ROS so the script works from a plain shell ----------
    # (only sources humble if no ROS distro is already active, to respect the user's env)
    set +e
    if [ -z "${ROS_DISTRO:-}" ] && [ -f /opt/ros/humble/setup.bash ]; then
        print_info "Sourcing /opt/ros/humble/setup.bash"
        source /opt/ros/humble/setup.bash
    fi
    if [ -f "${WORKSPACE_ROOT}/install/setup.bash" ]; then
        print_info "Sourcing ${WORKSPACE_ROOT}/install/setup.bash"
        source "${WORKSPACE_ROOT}/install/setup.bash"
    else
        print_info "install/setup.bash not found yet (first build?) - colcon will create it."
    fi
    set -e

    echo "======================================"
    print_info "ROS Multi-Robot Package Creator"
    echo "======================================"
    echo ""

    local package_name
    local num_robots

    # static_objects (optional) are passed verbatim into robots.json via this env
    # var; default to none. Only the JSON/RABIT path can carry them today.
    local STATIC_OBJECTS_JSON="[]"

    if [ -n "$FROM_JSON_PATH" ]; then
        load_from_json "$FROM_JSON_PATH"
        package_name="$PACKAGE_NAME_FROM_JSON"
        LAUNCH_RVIZ="$LAUNCH_RVIZ_FROM_JSON"
        num_robots="${#JSON_ROBOT_NAMES[@]}"
        STATIC_OBJECTS_JSON="$(python3 -c 'import json,sys; print(json.dumps(json.load(open(sys.argv[1])).get("static_objects", [])))' "$FROM_JSON_PATH")"
        print_info "Loaded from JSON: $FROM_JSON_PATH"
        print_info "  package=\"$package_name\"  launch_rviz=$LAUNCH_RVIZ  arms=(${JSON_ROBOT_NAMES[*]})"
    else
        # ---- Interactive prompts ----------------------------------------
        echo -n "Enter package name: "
        read package_name
        if [ -z "$package_name" ]; then
            print_error "Package name cannot be empty"
            exit 1
        fi
        print_info "Package name set to: $package_name"

        num_robots=$(get_number_input "Enter number of robots" 1 10)
        print_info "Number of robots: $num_robots"

        for ((i=1; i<=num_robots; i++)); do
            echo ""
            echo "======================================"
            get_robot_config "$i"
        done

        echo ""
        echo -n "Launch RViz with the demo? (Y/n): "
        read launch_rviz_input
        case "$launch_rviz_input" in
            [Nn]*) LAUNCH_RVIZ="false" ;;
            *)     LAUNCH_RVIZ="true"  ;;
        esac
        print_info "Launch RViz: $LAUNCH_RVIZ"

        display_summary "$num_robots"

        echo -n "Generate ROS package with this configuration? (y/N): "
        read confirm
        if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
            print_warning "Package generation cancelled"
            exit 0
        fi
    fi

    # ---- Common generation path ------------------------------------------
    print_info "Creating package structure under src/generated..."

  # Ensure the generated-packages directory exists
  mkdir -p "${GENERATED_DIR}"

  # Define package directory inside src/generated
  local PKG_DIR="${GENERATED_DIR}/${package_name}"
    
  # Create directories
  mkdir -p "${PKG_DIR}/urdf"
  mkdir -p "${PKG_DIR}/config"
  mkdir -p "${PKG_DIR}/launch"
    # Prepare robot names and specs
    robot_names=()
    robot_specs=()
    initial_positions=()
    if [ -n "$FROM_JSON_PATH" ]; then
      robot_names=("${JSON_ROBOT_NAMES[@]}")
      robot_specs=("${JSON_ROBOT_SPECS[@]}")
      initial_positions=("${JSON_INITIAL_POSITIONS[@]}")
    else
      for ((i=1; i<=num_robots; i++)); do
        robot_names+=("robot${i}")
        robot_specs+=("robot${i}:${ROBOT_UR_TYPES[$((i-1))]}:${ROBOT_X_POSITIONS[$((i-1))]}:${ROBOT_Y_POSITIONS[$((i-1))]}:${ROBOT_Z_POSITIONS[$((i-1))]}:${ROBOT_ROLLS[$((i-1))]}:${ROBOT_PITCHES[$((i-1))]}:${ROBOT_YAWS[$((i-1))]}:${ROBOT_SHOULDER_PANS[$((i-1))]}:${ROBOT_SHOULDER_LIFTS[$((i-1))]}:${ROBOT_ELBOWS[$((i-1))]}:${ROBOT_WRIST_1S[$((i-1))]}:${ROBOT_WRIST_2S[$((i-1))]}:${ROBOT_WRIST_3S[$((i-1))]}")
        initial_positions+=("robot${i}:${ROBOT_SHOULDER_PANS[$((i-1))]},${ROBOT_SHOULDER_LIFTS[$((i-1))]},${ROBOT_ELBOWS[$((i-1))]},${ROBOT_WRIST_1S[$((i-1))]},${ROBOT_WRIST_2S[$((i-1))]},${ROBOT_WRIST_3S[$((i-1))]}")
      done
    fi

    # Generate all files using helper scripts
    bash "${SCRIPT_DIR}/helpers/generate_cmakelists.sh" "$package_name" "$PKG_DIR"
    bash "${SCRIPT_DIR}/helpers/generate_package_xml.sh" "$package_name" "$PKG_DIR"
    bash "${SCRIPT_DIR}/helpers/generate_demo_launch.sh" "$package_name" "$PKG_DIR"
    STATIC_OBJECTS_JSON="$STATIC_OBJECTS_JSON" bash "${SCRIPT_DIR}/helpers/generate_robots_json.sh" "$package_name" "$PKG_DIR" "$LAUNCH_RVIZ" "${robot_specs[@]}"
    bash "${SCRIPT_DIR}/helpers/generate_world_sdf.sh" "$package_name" "$PKG_DIR"
    bash "${SCRIPT_DIR}/helpers/generate_joint_limits.sh" "$package_name" "$PKG_DIR" "${robot_names[@]}"
    bash "${SCRIPT_DIR}/helpers/generate_kinematics.sh" "$package_name" "$PKG_DIR" "${robot_names[@]}"
    bash "${SCRIPT_DIR}/helpers/generate_initial_positions.sh" "$package_name" "$PKG_DIR" "${initial_positions[@]}"
    controller_args=()
    for name in "${robot_names[@]}"; do
      joints="${name}_shoulder_pan_joint,${name}_shoulder_lift_joint,${name}_elbow_joint,${name}_wrist_1_joint,${name}_wrist_2_joint,${name}_wrist_3_joint"
      controller_args+=("${name}_joint_trajectory_controller:$joints")
    done
    bash "${SCRIPT_DIR}/helpers/generate_controllers.sh" "$package_name" "$PKG_DIR" "${controller_args[@]}"
    bash "${SCRIPT_DIR}/helpers/generate_moveit_controllers.sh" "$package_name" "$PKG_DIR" "${controller_args[@]}"
    bash "${SCRIPT_DIR}/helpers/generate_srdf.sh" "$package_name" "$PKG_DIR" "${robot_names[@]}"
    bash "${SCRIPT_DIR}/helpers/generate_ompl_planning.sh" "$package_name" "$PKG_DIR" "${robot_names[@]}"
    bash "${SCRIPT_DIR}/helpers/generate_rviz_config.sh" "$package_name" "$PKG_DIR" "${robot_names[@]}"

  # Generate launch script for the new package
  bash "${SCRIPT_DIR}/helpers/generate_launch_script.sh" "$package_name" "$PKG_DIR"
    # Thin demo workflow that drives this package via the multi_arm_control library
    bash "${SCRIPT_DIR}/helpers/generate_workflow_demo.sh" "$package_name" "$PKG_DIR"
    # Launch-time node that adds static_objects to the MoveIt planning scene
    bash "${SCRIPT_DIR}/helpers/generate_scene_publisher.sh" "$package_name" "$PKG_DIR"
    bash "${SCRIPT_DIR}/helpers/generate_sensors_3d.sh" "$package_name" "$PKG_DIR"
    bash "${SCRIPT_DIR}/helpers/generate_pilz_cartesian_limits.sh" "$package_name" "$PKG_DIR"
    bash "${SCRIPT_DIR}/helpers/generate_pkg_xacro.sh" "$package_name" "$PKG_DIR" "${robot_specs[@]}"
    bash "${SCRIPT_DIR}/helpers/generate_robot_description_template.sh" "$package_name" "$PKG_DIR" "${robot_specs[@]}"
    bash "${SCRIPT_DIR}/helpers/generate_robot_description_wrapper.sh" "$package_name" "$PKG_DIR"
    bash "${SCRIPT_DIR}/helpers/generate_ros2_control_xacro.sh" "$package_name" "$PKG_DIR" "${robot_names[@]}"
    bash "${SCRIPT_DIR}/helpers/generate_static_robot_description.sh" "$package_name" "$PKG_DIR"
    

  # Expand the generated XACRO into a URDF next to it
  local XACRO_PATH="${PKG_DIR}/urdf/${package_name}.urdf.xacro"
  local URDF_PATH="${PKG_DIR}/urdf/${package_name}.urdf"
  if [ -f "$XACRO_PATH" ]; then
    expand_xacro_to_urdf "$XACRO_PATH" "$URDF_PATH"
  else
    print_error "Expected XACRO not found at $XACRO_PATH"
    exit 1
  fi
    
    # package.xml is written earlier by helpers/generate_package_xml.sh (the single
    # authoritative writer); no inline overwrite here so its full dependency set
    # (MoveIt, RViz, controllers, the scene_publisher runtime deps, and the
    # multi_arm_lab_sim_description model library) is preserved.

    # Create CMakeLists.txt
  cat > "${PKG_DIR}/CMakeLists.txt" << EOF
cmake_minimum_required(VERSION 3.8)
project(${package_name})

if(CMAKE_COMPILER_IS_GNUCXX OR CMAKE_CXX_COMPILER_ID MATCHES "Clang")
  add_compile_options(-Wall -Wextra -Wpedantic)
endif()

# find dependencies
find_package(ament_cmake REQUIRED)

# Install directories
install(
  DIRECTORY config launch urdf
  DESTINATION share/\${PROJECT_NAME}
)

# Install the launch-time planning-scene publisher as a runnable node
if(EXISTS "\${CMAKE_CURRENT_SOURCE_DIR}/scripts/scene_publisher.py")
  install(
    PROGRAMS scripts/scene_publisher.py
    DESTINATION lib/\${PROJECT_NAME}
  )
endif()

if(BUILD_TESTING)
  find_package(ament_lint_auto REQUIRED)
  ament_lint_auto_find_test_dependencies()
endif()

ament_package()
EOF


  print_success "Package '${package_name}' created successfully at: ${PKG_DIR}"

    # ---- optional colcon build -----------------------------------------------
    if [ "$NO_BUILD" = "1" ]; then
        print_info "Skipping build (--no-build). To finish: colcon build --packages-select ${package_name}"
    elif ! command -v colcon >/dev/null 2>&1; then
        print_warning "colcon not found; skipping build. (Did you 'source /opt/ros/humble/setup.bash'?)"
        print_warning "Run manually: colcon build --packages-select ${package_name}"
    else
        print_info "Building: colcon build --packages-select ${package_name}"
        if ( cd "$WORKSPACE_ROOT" && colcon build --packages-select "$package_name" ); then
            print_success "Built ${package_name}"
        else
            print_error "colcon build failed for ${package_name}"
            exit 1
        fi
    fi

    echo ""
    print_info "Next steps:"
    echo "  source install/setup.bash                          # if not already"
    echo "  ./scripts/launch-wrappers/launch_${package_name}              # Gazebo + move_group (+ RViz if launch_rviz=true)"
    echo "  python3 src/generated/${package_name}/scripts/workflow_demo.py   # run the demo workflow"
    echo ""
    print_success "Done!"
}

# Run main function
main "$@"