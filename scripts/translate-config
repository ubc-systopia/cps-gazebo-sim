#!/usr/bin/env python3
"""translate-config - Translate a general-schema lab config (e.g. rabit-config-2.json)
into the flat diff_robots.json spec that create-ros-pkg --from-json consumes.

Usage:
    scripts/translate-config <source.json> <destination.json>

The source must follow general-schema-2.json (i.e. each robot arm carries a
`model` and each instance carries `initial_joints`). One robot_arms entry with N
instances is flattened into N arms in the output. Everything that isn't relevant
to ROS package generation (action_devices, passive_objects, environment) is
dropped.
"""

import argparse
import json
import math
import re
import sys

# class_name (from the experiment script) -> supported ur_description model.
CLASS_TO_MODEL = {
    "UR3Arm": "ur3", "UR3eArm": "ur3e", "UR5Arm": "ur5", "UR5eArm": "ur5e",
    "UR10Arm": "ur10", "UR10eArm": "ur10e", "UR16eArm": "ur16e",
    "UR20Arm": "ur20", "UR30Arm": "ur30",
}
VALID_MODELS = {"ur3", "ur3e", "ur5", "ur5e", "ur10", "ur10e", "ur16e", "ur20", "ur30"}
JOINTS = ("shoulder_pan", "shoulder_lift", "elbow", "wrist_1", "wrist_2", "wrist_3")


def die(msg):
    print(f"[ERROR] {msg}", file=sys.stderr)
    sys.exit(1)


def slugify(key, used):
    """Turn an arbitrary instance key (e.g. an IP) into a unique ROS-safe name."""
    name = re.sub(r"[^A-Za-z0-9_]", "_", str(key)).strip("_")
    name = re.sub(r"_+", "_", name)
    if not name:
        name = "arm"
    if name[0].isdigit():
        name = "arm_" + name
    candidate, n = name, 2
    while candidate in used:
        candidate = f"{name}_{n}"
        n += 1
    used.add(candidate)
    return candidate


def resolve_model(arm):
    model = arm.get("model") or CLASS_TO_MODEL.get(arm.get("class_name", ""))
    if model not in VALID_MODELS:
        die(f"cannot resolve a supported UR model for arm "
            f"(class_name={arm.get('class_name')!r}, model={arm.get('model')!r}). "
            f"Add a `model` field (one of {sorted(VALID_MODELS)}).")
    return model


def geometry_from_shape(shape):
    """Map an SDL shape -> a static_objects primitive (box/cylinder/sphere).
    Returns None for shape types static_objects can't represent."""
    st = (shape.get("shape_type") or "").lower()
    d = shape.get("dimensions") or {}
    if st == "cuboid":
        return {"box": [float(d.get("length", 0.0)), float(d.get("width", 0.0)), float(d.get("height", 0.0))]}
    if st == "cylinder":
        return {"cylinder": {"radius": float(d.get("radius", 0.0)), "length": float(d.get("height", 0.0))}}
    if st == "sphere":
        return {"sphere": {"radius": float(d.get("radius", 0.0))}}
    return None  # hemisphere / pyramid have no static_objects equivalent


def _make_static_object(name_key, shape, loc, ori, used, what, model=None):
    """Build one static_object dict, or None if there's no usable geometry.

    A `model` reference (include/mesh/scale) takes precedence over the primitive
    `shape`: the object renders the model in Gazebo (include) and/or uses its mesh
    for MoveIt collision. If neither a model nor a supported shape is present the
    object is skipped."""
    loc = loc or {}
    ori = ori or {}
    obj = {
        "name": slugify(name_key, used),
        "pose": [
            float(loc.get("x", 0.0)), float(loc.get("y", 0.0)), float(loc.get("z", 0.0)),
            float(ori.get("R", 0.0)), float(ori.get("P", 0.0)), float(ori.get("Y", 0.0)),
        ],
    }
    model = model or {}
    if model.get("include") or model.get("mesh"):
        if model.get("include"):
            obj["include"] = model["include"]
        if model.get("mesh"):
            obj["mesh"] = model["mesh"]
        if model.get("scale") is not None:
            obj["scale"] = model["scale"]
        return obj
    geo = geometry_from_shape(shape or {})
    if geo is None:
        sys.stderr.write(
            f"[WARN] skipping {what} {name_key!r}: "
            f"unsupported shape_type {(shape or {}).get('shape_type')!r} and no model reference\n")
        return None
    obj.update(geo)
    return obj


def translate_passive_objects(src, used):
    """Map SDL passive_objects -> flat static_objects."""
    objects = []
    for po in src.get("passive_objects", []):
        obj = _make_static_object(po.get("key", "object"), po.get("shape"),
                                  po.get("initial_location"), po.get("initial_orientation"),
                                  used, "passive_object", po.get("model"))
        if obj is not None:
            objects.append(obj)
    return objects


def translate_action_devices(src, used):
    """Map each SDL action_devices[].instances[] -> a static_object (physical obstacle)."""
    objects = []
    for dev in src.get("action_devices", []):
        for inst in dev.get("instances", []):
            obj = _make_static_object(inst.get("key", "device"), inst.get("shape"),
                                      inst.get("initial_location"), inst.get("initial_orientation"),
                                      used, "action_device instance", inst.get("model"))
            if obj is not None:
                objects.append(obj)
    return objects


def translate_walls(src, used):
    """Map SDL environment walls (parallel walls_coords / walls_shapes arrays) -> static_objects."""
    env = src.get("environment") or {}
    coords = env.get("walls_coords") or []
    shapes = env.get("walls_shapes") or []
    objects = []
    for i, shape in enumerate(shapes):
        loc = coords[i] if i < len(coords) else {}
        # walls carry no orientation field today, so they default axis-aligned.
        obj = _make_static_object(f"wall_{i + 1}", shape, loc, None, used, "wall")
        if obj is not None:
            objects.append(obj)
    return objects


def translate(src):
    if "package_name" not in src:
        die("source is missing top-level `package_name`.")
    out = {
        "package_name": src["package_name"],
        "launch_rviz": bool(src.get("launch_rviz", True)),
    }
    # Pass through optional MoveIt ground-plane controls if present.
    for k in ("avoid_ground", "ground_level"):
        if k in src:
            out[k] = src[k]

    # Static world objects from SDL passive_objects, action_devices and walls.
    # They share one name namespace (separate from arm keys) so names stay unique.
    used_obj = set()
    static_objects = (
        translate_passive_objects(src, used_obj)
        + translate_action_devices(src, used_obj)
        + translate_walls(src, used_obj)
    )
    if static_objects:
        out["static_objects"] = static_objects

    out["robot_arms"] = []
    used_keys = set()
    for arm in src.get("robot_arms", []):
        model = resolve_model(arm)
        for inst in arm.get("instances", []):
            rt = inst.get("robot_transformation") or {}
            ij = inst.get("initial_joints") or {}
            out["robot_arms"].append({
                "key": slugify(inst.get("key", "arm"), used_keys),
                "model": model,
                "base_coordinates": {
                    "x": rt.get("base_x", 0.0),
                    "y": rt.get("base_y", 0.0),
                    "z": rt.get("base_z", 0.0),
                    "R": rt.get("base_roll", 0.0),
                    "P": rt.get("base_pitch", 0.0),
                    "Y": math.radians(rt.get("rotation_degree", 0.0)),
                },
                "initial_joints": {j: ij.get(j, 0.0) for j in JOINTS},
            })
    if not out["robot_arms"]:
        die("source produced no robot arms (no robot_arms[].instances[] found).")
    return out


def main():
    p = argparse.ArgumentParser(description="Translate a general-schema lab config into a diff_robots.json spec.")
    p.add_argument("source", help="path to the general-schema config (e.g. rabit-config-2.json)")
    p.add_argument("destination", help="path to write the diff_robots.json-style spec")
    args = p.parse_args()

    try:
        with open(args.source) as f:
            src = json.load(f)
    except FileNotFoundError:
        die(f"source file not found: {args.source}")
    except json.JSONDecodeError as e:
        die(f"source is not valid JSON: {e}")

    out = translate(src)

    with open(args.destination, "w") as f:
        json.dump(out, f, indent=2)
        f.write("\n")

    objs = [o["name"] for o in out.get("static_objects", [])]
    print(f"[OK] wrote {args.destination}  "
          f"(package={out['package_name']}, arms={[a['key'] for a in out['robot_arms']]}, "
          f"static_objects={objs})")


if __name__ == "__main__":
    main()
