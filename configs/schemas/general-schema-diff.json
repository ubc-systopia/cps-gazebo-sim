[
  {
    "op": "add",
    "path": "/properties/launch_rviz",
    "value": {
      "description": "Whether the generated demo.launch.py should start RViz",
      "type": "boolean"
    }
  },
  {
    "op": "add",
    "path": "/properties/package_name",
    "value": {
      "description": "Name of the ROS package to generate for this lab",
      "type": "string"
    }
  },
  {
    "op": "add",
    "path": "/properties/passive_objects/items/properties/initial_orientation",
    "value": {
      "description": "Object orientation [R, P, Y] in radians (roll about X, pitch about Y, yaw about Z). Optional; defaults to 0,0,0. Maps to the roll/pitch/yaw components of the generated static_objects pose so objects can be placed at angles.",
      "type": "object",
      "properties": {
        "R": {
          "type": "number"
        },
        "P": {
          "type": "number"
        },
        "Y": {
          "type": "number"
        }
      }
    }
  },
  {
    "op": "add",
    "path": "/properties/action_devices/items/properties/instances/items/properties/initial_orientation",
    "value": {
      "description": "Instance orientation [R, P, Y] in radians. Optional; defaults to 0,0,0. Maps to the roll/pitch/yaw of the generated static_objects pose.",
      "type": "object",
      "properties": {
        "R": {
          "type": "number"
        },
        "P": {
          "type": "number"
        },
        "Y": {
          "type": "number"
        }
      }
    }
  },
  {
    "op": "add",
    "path": "/properties/robot_arms/items/properties/model",
    "value": {
      "description": "UR model used to generate the ROS package; must be one of the supported ur_description types",
      "type": "string",
      "enum": [
        "ur3",
        "ur3e",
        "ur5",
        "ur5e",
        "ur10",
        "ur10e",
        "ur16e",
        "ur20",
        "ur30"
      ]
    }
  },
  {
    "op": "add",
    "path": "/properties/robot_arms/items/properties/instances/items/properties/initial_joints",
    "value": {
      "description": "Initial joint angles (radians) used to seed the ROS package's ros2_control state interfaces and initial_positions.yaml",
      "type": "object",
      "properties": {
        "shoulder_pan": {
          "type": "number"
        },
        "shoulder_lift": {
          "type": "number"
        },
        "elbow": {
          "type": "number"
        },
        "wrist_1": {
          "type": "number"
        },
        "wrist_2": {
          "type": "number"
        },
        "wrist_3": {
          "type": "number"
        }
      }
    }
  },
  {
    "op": "add",
    "path": "/properties/robot_arms/items/properties/instances/items/properties/robot_transformation/properties/base_pitch",
    "value": {
      "description": "Base pitch about Y in radians (P for ROS base_coordinates)",
      "type": "number"
    }
  },
  {
    "op": "add",
    "path": "/properties/robot_arms/items/properties/instances/items/properties/robot_transformation/properties/base_roll",
    "value": {
      "description": "Base roll about X in radians (R for ROS base_coordinates)",
      "type": "number"
    }
  }
]
