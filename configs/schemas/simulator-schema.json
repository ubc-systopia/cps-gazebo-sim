{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "diff_robots package spec",
  "description": "Flat spec consumed by scripts/create-ros-pkg --from-json. Numeric fields accept either numbers or numeric strings.",
  "type": "object",
  "required": [
    "package_name",
    "robot_arms"
  ],
  "additionalProperties": false,
  "properties": {
    "package_name": {
      "description": "ROS package name to generate; must be a valid ament package name",
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "launch_rviz": {
      "description": "Whether the generated demo.launch.py should start RViz",
      "type": "boolean"
    },
    "avoid_ground": {
      "description": "Add a floor collision plane to the MoveIt planning scene so the arm won't plan through z<0. Default true.",
      "type": "boolean"
    },
    "ground_level": {
      "description": "Height (metres) of the floor collision plane (its top sits 2 cm below this). Default 0.0.",
      "type": "number"
    },
    "static_objects": {
      "description": "Static (immovable) objects spawned into the Gazebo world. Rendered into config/world.sdf by generate_world_sdf.sh and loaded by demo.launch.py.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "pose"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "description": "Unique model name in the world",
            "type": "string"
          },
          "pose": {
            "description": "World pose [x, y, z, roll, pitch, yaw] (metres, radians)",
            "type": "array",
            "items": { "type": "number" },
            "minItems": 6,
            "maxItems": 6
          },
          "box": {
            "description": "Box geometry [size_x, size_y, size_z] (metres)",
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          },
          "cylinder": {
            "description": "Cylinder geometry",
            "type": "object",
            "additionalProperties": false,
            "required": ["radius", "length"],
            "properties": {
              "radius": { "type": "number" },
              "length": { "type": "number" }
            }
          },
          "sphere": {
            "description": "Sphere geometry",
            "type": "object",
            "additionalProperties": false,
            "required": ["radius"],
            "properties": { "radius": { "type": "number" } }
          },
          "include": {
            "description": "package:// or model:// URI of a reusable Gazebo model, used for the Gazebo visual. May be combined with 'mesh' (which then provides the MoveIt collision geometry).",
            "type": "string"
          },
          "mesh": {
            "description": "package:// or file:// path to a mesh file (.dae/.stl/.obj) loaded as the MoveIt collision geometry, so the arm plans around the true shape. Typically paired with 'include' for the Gazebo visual.",
            "type": "string"
          },
          "scale": {
            "description": "Optional scale (single number or [sx, sy, sz]) for a BARE mesh that has no owning model (no 'include'). When the mesh belongs to a model (the usual include+mesh case) scale is read from that model's model.sdf instead -- the single source of truth that Gazebo and MoveIt both use -- and this field is ignored; resize it with scripts/resize-model.",
            "oneOf": [
              { "type": "number" },
              {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 3,
                "maxItems": 3
              }
            ]
          }
        }
      }
    },
    "robot_arms": {
      "description": "One entry per physical arm",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "key",
          "model",
          "base_coordinates",
          "initial_joints"
        ],
        "additionalProperties": false,
        "properties": {
          "key": {
            "description": "ROS-safe unique arm name (tf_prefix / joint-name root)",
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
          },
          "model": {
            "description": "Supported ur_description model",
            "type": "string",
            "enum": [
              "ur3",
              "ur3e",
              "ur5",
              "ur5e",
              "ur10",
              "ur10e",
              "ur16e",
              "ur20",
              "ur30"
            ]
          },
          "base_coordinates": {
            "description": "Base pose in the world frame: x/y/z metres, R/P/Y radians",
            "type": "object",
            "required": [
              "x",
              "y",
              "z",
              "R",
              "P",
              "Y"
            ],
            "additionalProperties": false,
            "properties": {
              "x": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "y": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "z": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "R": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "P": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "Y": {
                "type": [
                  "number",
                  "string"
                ]
              }
            }
          },
          "initial_joints": {
            "description": "Initial joint angles (radians)",
            "type": "object",
            "required": [
              "shoulder_pan",
              "shoulder_lift",
              "elbow",
              "wrist_1",
              "wrist_2",
              "wrist_3"
            ],
            "additionalProperties": false,
            "properties": {
              "shoulder_pan": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "shoulder_lift": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "elbow": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "wrist_1": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "wrist_2": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "wrist_3": {
                "type": [
                  "number",
                  "string"
                ]
              }
            }
          }
        }
      }
    }
  }
}
